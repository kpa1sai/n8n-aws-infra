# Copy to terraform.tfvars for local runs (CI passes these as -var flags instead
# and never writes this file — see .github/workflows/deploy.yml).

aws_region       = "us-east-1"
project_name     = "n8n-server"
instance_type    = "t3.micro"
allowed_ssh_cidr = "203.0.113.5/32" # replace with your IP/32
root_volume_size = 20
