# Managed by Ansible — do not edit by hand, changes will be overwritten on next deploy.

{% set effective_host = n8n_domain if n8n_domain else (public_ip | replace('.', '-')) + '.sslip.io' %}
# n8n v2+ has no basic auth — the owner account is pre-provisioned from env vars
# instead, so there's no public "create owner account" screen for anyone else to
# claim before the real owner logs in.
N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true
N8N_INSTANCE_OWNER_EMAIL={{ n8n_owner_email }}
N8N_INSTANCE_OWNER_FIRST_NAME={{ n8n_owner_first_name }}
N8N_INSTANCE_OWNER_LAST_NAME={{ n8n_owner_last_name }}
N8N_INSTANCE_OWNER_PASSWORD_HASH={{ n8n_owner_password_hash }}
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD={{ postgres_password }}

# Always HTTPS: N8N_DOMAIN if set, otherwise a free sslip.io hostname that maps
# to the Elastic IP, so Caddy can auto-issue a real Let's Encrypt cert either way.
N8N_HOST={{ effective_host }}
N8N_PROTOCOL=https
WEBHOOK_URL=https://{{ effective_host }}/
CADDY_SITE_ADDRESS={{ effective_host }}
